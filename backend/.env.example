ENVIRONMENT=development
PORT=4000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/tasktrack?retryWrites=true&w=majority
USE_MEMORY_DB=false
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DESKTOP=30d
CORS_ORIGIN=http://localhost:5175,http://localhost:5173
SEED_EMAIL=riya@acme.dev
SEED_PASSWORD=Password123
APP_URL=http://localhost:5175
# Optional — without SMTP, invite links are logged + returned in the API
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Cloudflare R2 (S3-compatible). When set, uploads go to R2; otherwise local /uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Optional — defaults to https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Cloudinary — chat images only; user/task images use R2
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
